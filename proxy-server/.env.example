# Local-dev environment. Copy to `.env` and edit. Never commit `.env`.

# Default store: a local SQLite file — no server to deploy. For multi-worker /
# high-concurrency, install the `postgres` extra and use a postgresql+asyncpg:// URL:
#   PLATFORM_DATABASE_URL=postgresql+asyncpg://platform:platform@127.0.0.1:5433/platform
PLATFORM_DATABASE_URL=sqlite+aiosqlite:///./hexa.sqlite
PLATFORM_JWT_SECRET=change-me-to-a-long-random-string
PLATFORM_AGENT_BACKEND_URL=http://127.0.0.1:8880
PLATFORM_HOST=127.0.0.1
PLATFORM_PORT=8800
PLATFORM_LOG_LEVEL=info
