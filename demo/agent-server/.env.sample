# agent-server (the developer's backend) secrets.
# Copy to `.env` (gitignored) and fill in. Loaded at startup by __main__.py.
# Real environment variables take precedence over values in this file.

# OpenAI model key for the healthcare agent. When set here it is the SOURCE OF
# TRUTH for model calls — it takes priority over a key entered in the HexaUI
# Settings UI. Leave blank to rely solely on the UI-forwarded key.
OPENAI_API_KEY=

# HexGate platform key — only needed for the HexGate-wrapped path
# (HEALTHCARE_HEXGATE=1). Read directly by HexgateRunner(). Leave blank otherwise.
HEXGATE_KEY=
