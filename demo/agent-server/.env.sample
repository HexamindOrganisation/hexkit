# agent-server secrets. Copy to `.env` (gitignored); real env vars take precedence.

# OpenAI model key. When set here, takes priority over the key from the HexaUI UI.
OPENAI_API_KEY=

# HexGate platform key. Set this to route the healthcare agent through the
# HexGate-gated path (optional HEXGATE_ROLE, default "nurse"); leave empty for plain SDK.
HEXGATE_KEY=
