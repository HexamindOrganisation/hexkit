# agent-server secrets. Copy to `.env` (gitignored); real env vars take precedence.

# OpenAI model key. When set here, takes priority over the key from the HexaUI UI.
OPENAI_API_KEY=

# HexGate platform key. Set this to route the healthcare and devops agents
# through the HexGate-gated path (every tool call is policy-checked); leave
# empty for the plain SDK path.
HEXGATE_KEY=

# Role the HexGate path runs as. Normally the role comes from the signed-in
# HexUI user (context.user.role, set in the Settings UI). HEXGATE_ROLE is only
# the fallback for standalone runs that send no user block (e.g. verify_backend.py);
# unset, healthcare defaults to "nurse" and devops to "operator".
HEXGATE_ROLE=
