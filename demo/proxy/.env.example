# Local-dev environment. Copy to `.env` and edit. Never commit `.env`.

PLATFORM_DATABASE_URL=postgresql+asyncpg://platform:platform@127.0.0.1:5432/platform
PLATFORM_JWT_SECRET=change-me-to-a-long-random-string
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PLATFORM_FERNET_KEY=
PLATFORM_RUNTIME_URL=http://127.0.0.1:8080
PLATFORM_HOST=127.0.0.1
PLATFORM_PORT=8000
PLATFORM_LOG_LEVEL=info

# Tests use a separate database (created/dropped by the test fixture).
PLATFORM_TEST_DATABASE_URL=postgresql+asyncpg://platform:platform@127.0.0.1:5432/platform_test
